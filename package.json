  "description": "Sistema de gestión para pollería — Backend Módulo 1: Producción + Stock + Transferencias",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
