// Schema Prisma — Sistema de Gestión Pollería
// Módulo 1 + entidades transversales completas (ver CLAUDE.md §9)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TipoSucursal {
  PRODUCCION
  VENTA
}

enum Rol {
  ADMINISTRADOR
  SOCIO
  ENCARGADO
  CAJERO
  PRODUCCION
}

enum TipoProducto {
  MATERIA_PRIMA
  ELABORADO
  REVENTA
  // Bundle de otros productos vendido a un precio propio (no calculado por
  // descuento — el precio del combo es un dato, igual que cualquier Precio).
  // No tiene stock propio: vender un combo (módulo 2/POS, futuro) descuenta
  // el stock de cada ComboComponente por su cantidad, nunca del combo en sí.
  COMBO
}

enum UnidadDeMedida {
  KG
  UNIDAD
}

enum TipoMovimientoStock {
  INGRESO_COMPRA
  CONSUMO_PRODUCCION
  PRODUCCION_ALTA
  DESPERDICIO_PRODUCCION
  TRANSFERENCIA_SALIDA
  TRANSFERENCIA_ENTRADA
  VENTA
  ANULACION_REPOSICION
  ATENCION
  MERMA_QUEMADO
  RETORNO_A_PRODUCCION
  MARCADO_POLLO
  AJUSTE
}

enum TipoAlerta {
  DESVIO_PRODUCCION
  DISCREPANCIA_TRANSFERENCIA
  DISCREPANCIA_CAJA
  BLOQUEO_TURNO
  STOCK_MINIMO
}

enum EstadoLoteProduccion {
  ABIERTO
  CERRADO
}

enum EstadoTransferencia {
  PENDIENTE_RECEPCION
  CONFIRMADA
  CONFIRMADA_CON_DISCREPANCIA
}

// ── Módulo 2 — POS + Caja y Turnos (CLAUDE.md del módulo 2, ver §3) ──

enum EstadoTurno {
  ABIERTO
  BLOQUEADO
  CERRADO
}

enum MomentoArqueo {
  APERTURA
  CIERRE
}

enum TipoArqueo {
  EFECTIVO
  POLLOS_MARCADOS
}

enum ResultadoArqueo {
  COINCIDE
  FALTANTE
  SOBRANTE
}

enum EstadoBloqueo {
  BLOQUEADO
  DESBLOQUEADO
}

enum TipoDesbloqueo {
  REMOTO
  CLAVE_EMERGENCIA
}

enum TipoPedido {
  PRESENCIAL
  A_RETIRAR
}

enum EstadoPedido {
  EN_PREPARACION
  LISTO
  ENTREGADO
  LISTO_NO_RETIRADO
  REASIGNADO
  PERDIDO
  ANULADO
}

enum MedioPago {
  EFECTIVO
  DEBITO
  CREDITO
  MERCADO_PAGO
  TRANSFERENCIA
}

enum TipoCostoCero {
  DESPERDICIO_QUEMADO
  RETORNO_A_PRODUCCION
}

// Selector CERRADO de quién retira — nunca texto libre (CLAUDE.md módulo 1 §8)
enum SocioRetiro {
  ARIEL
  ELIANA
  EMA
}

enum TipoTicket {
  NUEVO
  ACTUALIZACION
  ANULACION
}

// ─────────────────────────────────────────────
// TRANSVERSALES
// ─────────────────────────────────────────────

model Sucursal {
  id        Int          @id @default(autoincrement())
  nombre    String       @unique
  tipo      TipoSucursal
  direccion String?
  activa    Boolean      @default(true)

  movimientosStock           MovimientoStock[]
  ingresosMercaderia         IngresoMercaderia[]
  transferenciasOrigen       Transferencia[]            @relation("TransferenciaOrigen")
  transferenciasDestino      Transferencia[]            @relation("TransferenciaDestino")
  usuarios                   Usuario[]
  // Módulo 2
  turnos                     Turno[]
  pedidos                    Pedido[]
  atenciones                 Atencion[]
  eventosMarcadoPollo        EventoMarcadoPollo[]
  configuracionesStockMinimo ConfiguracionStockMinimo[]

  @@map("sucursales")
}

model Usuario {
  id           Int       @id @default(autoincrement())
  nombre       String
  username     String    @unique
  passwordHash String
  rol          Rol
  activo       Boolean   @default(true)
  // Sucursal fija del usuario (relevante para CAJERO/ENCARGADO: define de qué
  // local es y sobre qué transferencias puede operar — ver transferencias.service.ts)
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])
  sucursalId   Int?

  refreshTokens              RefreshToken[]
  movimientosStock           MovimientoStock[]
  registrosAuditoria         RegistroAuditoria[]
  preciosCreados             Precio[]
  ingresosMercaderia         IngresoMercaderia[]
  lotesProduccion            LoteDeProduccion[]
  transferenciasEmitidas     Transferencia[]      @relation("TransferenciaEmisor")
  transferenciasRecibidas    Transferencia[]      @relation("TransferenciaReceptor")
  // Módulo 2
  turnosComoCajero           Turno[]
  pedidosComoCajero          Pedido[]
  atenciones                 Atencion[]
  gastosDeCaja               GastoDeCaja[]
  retirosDeCajaRegistrados   RetiroDeCaja[]
  eventosMarcadoPollo        EventoMarcadoPollo[]
  clavesEmergenciaGeneradas  ClaveDeEmergencia[]
  bloqueosComoCajeroAnterior BloqueoDeTurno[]     @relation("BloqueoCajeroAnterior")
  bloqueosAutorizados        BloqueoDeTurno[]     @relation("BloqueoAutorizante")

  @@map("usuarios")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  expiraEn  DateTime
  revocado  Boolean  @default(false)
  creadoEn  DateTime @default(now())

  @@map("refresh_tokens")
}

model Producto {
  id             Int            @id @default(autoincrement())
  nombre         String         @unique
  categoria      String
  tipo           TipoProducto
  unidadDeMedida UnidadDeMedida
  activo         Boolean        @default(true)

  precios                    Precio[]
  movimientosStock           MovimientoStock[]
  lineasIngreso              LineaIngreso[]
  fichaTecnica               FichaTecnica?
  ingredientesDondeEsInsumo  IngredienteDeReceta[]
  insumosUsados              InsumoUsado[]
  lotesProduccion            LoteDeProduccion[]
  lineasTransferencia        LineaDeTransferencia[]
  // Solo relevante si tipo = COMBO: de qué productos se compone
  componentesDelCombo        ComboComponente[]          @relation("ComboDeProducto")
  // Solo relevante si este producto integra algún combo como componente
  usadoEnCombos              ComboComponente[]          @relation("ComponenteDeCombo")
  // Módulo 2
  itemsDePedido              ItemDePedido[]
  atenciones                 Atencion[]
  configuracionesStockMinimo ConfiguracionStockMinimo[]

  @@map("productos")
}

// Composición de un Producto tipo COMBO. El precio del combo vive en Precio
// (misma entidad/historial que cualquier producto) — acá solo se define DE
// QUÉ se arma y en qué cantidad (CLAUDE.md §9, propuesta validada 2026-07-13).
model ComboComponente {
  id                   Int      @id @default(autoincrement())
  combo                Producto @relation("ComboDeProducto", fields: [comboId], references: [id])
  comboId              Int
  productoComponente   Producto @relation("ComponenteDeCombo", fields: [productoComponenteId], references: [id])
  productoComponenteId Int
  cantidad             Decimal  @db.Decimal(12, 3)

  @@unique([comboId, productoComponenteId])
  @@map("combo_componentes")
}

model Precio {
  id         Int      @id @default(autoincrement())
  producto   Producto @relation(fields: [productoId], references: [id])
  productoId Int
  monto      Decimal  @db.Decimal(12, 2)
  // A qué cantidad pedida corresponde este monto. Default 1 = precio normal
  // por unidad (todo lo que no sea COMBO usa siempre 1). Para COMBO permite
  // una tabla de precio por volumen no lineal (ej: 1 pollo c/fritas $29.000,
  // pero 2 son $56.000, no $58.000) — dato real relevado de la planilla del
  // cliente, agregado 2026-07-13. Nunca se pisa: cambiar el precio de una
  // cantidad es un registro Precio nuevo con esa misma cantidad.
  cantidad   Int      @default(1)
  fechaDesde DateTime @default(now())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId  Int

  @@index([productoId, fechaDesde])
  @@index([productoId, cantidad, fechaDesde])
  @@map("precios")
}

// LA ENTIDAD CENTRAL: stock actual = SUM(cantidad) por producto+sucursal
model MovimientoStock {
  id         Int                 @id @default(autoincrement())
  producto   Producto            @relation(fields: [productoId], references: [id])
  productoId Int
  sucursal   Sucursal            @relation(fields: [sucursalId], references: [id])
  sucursalId Int
  tipo       TipoMovimientoStock
  cantidad   Decimal             @db.Decimal(12, 3) // positiva o negativa
  fechaHora  DateTime            @default(now())
  usuario    Usuario             @relation(fields: [usuarioId], references: [id])
  usuarioId  Int
  // referencia polimórfica al documento origen
  tipoOrigen String
  origenId   Int

  @@index([productoId, sucursalId])
  @@index([tipoOrigen, origenId])
  @@map("movimientos_stock")
}

model RegistroAuditoria {
  id              Int      @id @default(autoincrement())
  accion          String
  entidad         String
  entidadId       Int
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId       Int
  fechaHora       DateTime @default(now())
  datosAnteriores Json?
  datosNuevos     Json?

  @@index([entidad, entidadId])
  @@index([usuarioId])
  @@index([fechaHora])
  @@map("registros_auditoria")
}

model Alerta {
  id         Int        @id @default(autoincrement())
  tipo       TipoAlerta
  // referencia polimórfica al objeto disparador
  tipoOrigen String
  origenId   Int
  fechaHora  DateTime   @default(now())
  vista      Boolean    @default(false)
  detalle    Json // snapshot de datos relevantes (producto, cantidades, usuarios, desvío)

  @@index([vista])
  @@index([tipo])
  @@map("alertas")
}

// ─────────────────────────────────────────────
// MÓDULO 1 — FLUJO 1: INGRESO DE MERCADERÍA
// ─────────────────────────────────────────────

model Proveedor {
  id       Int     @id @default(autoincrement())
  nombre   String  @unique
  contacto String?
  activo   Boolean @default(true)
  esOtro   Boolean @default(false)

  ingresos IngresoMercaderia[]

  @@map("proveedores")
}

model IngresoMercaderia {
  id                      Int       @id @default(autoincrement())
  proveedor               Proveedor @relation(fields: [proveedorId], references: [id])
  proveedorId             Int
  comentarioProveedorOtro String?
  sucursal                Sucursal  @relation(fields: [sucursalId], references: [id])
  sucursalId              Int
  fechaHora               DateTime  @default(now())
  usuario                 Usuario   @relation(fields: [usuarioId], references: [id])
  usuarioId               Int
  fotoRemitoUrl           String?

  lineas LineaIngreso[]

  @@map("ingresos_mercaderia")
}

// = lote de ingreso trazable ("10 kg de nalga del 3/7")
model LineaIngreso {
  id                         Int               @id @default(autoincrement())
  ingresoMercaderia          IngresoMercaderia @relation(fields: [ingresoMercaderiaId], references: [id])
  ingresoMercaderiaId        Int
  producto                   Producto          @relation(fields: [productoId], references: [id])
  productoId                 Int
  cantidadSegunRemito        Decimal           @db.Decimal(12, 3)
  cantidadRealPesada         Decimal           @db.Decimal(12, 3)
  cantidadRestanteDisponible Decimal           @db.Decimal(12, 3)

  insumosUsados InsumoUsado[]

  @@index([productoId])
  @@map("lineas_ingreso")
}

// ─────────────────────────────────────────────
// MÓDULO 1 — FLUJO 2: PRODUCCIÓN
// ─────────────────────────────────────────────

model FichaTecnica {
  id                  Int      @id @default(autoincrement())
  productoElaborado   Producto @relation(fields: [productoElaboradoId], references: [id])
  productoElaboradoId Int      @unique

  versiones FichaTecnicaVersion[]

  @@map("fichas_tecnicas")
}

model FichaTecnicaVersion {
  id                     Int          @id @default(autoincrement())
  fichaTecnica           FichaTecnica @relation(fields: [fichaTecnicaId], references: [id])
  fichaTecnicaId         Int
  numeroVersion          Int
  fechaDesde             DateTime     @default(now())
  activa                 Boolean      @default(true)
  // unidades esperadas por unidad (KG) de insumo principal — referencia del cliente
  rendimientoEsperado    Decimal      @db.Decimal(12, 3)
  desperdicioEsperadoPct Decimal      @db.Decimal(5, 2)
  umbralDesvioAlertaPct  Decimal      @db.Decimal(5, 2)

  ingredientes    IngredienteDeReceta[]
  lotesProduccion LoteDeProduccion[]

  @@unique([fichaTecnicaId, numeroVersion])
  @@map("fichas_tecnicas_versiones")
}

model IngredienteDeReceta {
  id                         Int                 @id @default(autoincrement())
  fichaTecnicaVersion        FichaTecnicaVersion @relation(fields: [fichaTecnicaVersionId], references: [id])
  fichaTecnicaVersionId      Int
  productoInsumo             Producto            @relation(fields: [productoInsumoId], references: [id])
  productoInsumoId           Int
  cantidadPorUnidadProducida Decimal             @db.Decimal(12, 4)
  esPrincipal                Boolean             @default(false) // insumo principal: base del cálculo de rendimiento

  @@unique([fichaTecnicaVersionId, productoInsumoId])
  @@map("ingredientes_receta")
}

model LoteDeProduccion {
  id                       Int                  @id @default(autoincrement())
  productoElaborado        Producto             @relation(fields: [productoElaboradoId], references: [id])
  productoElaboradoId      Int
  fichaTecnicaVersion      FichaTecnicaVersion  @relation(fields: [fichaTecnicaVersionId], references: [id])
  fichaTecnicaVersionId    Int // versión CONGELADA al abrir el lote
  fechaHora                DateTime             @default(now())
  usuarioOperario          Usuario              @relation(fields: [usuarioOperarioId], references: [id])
  usuarioOperarioId        Int
  estado                   EstadoLoteProduccion @default(ABIERTO)
  unidadesProducidasReales Decimal?             @db.Decimal(12, 3)
  desperdicioRealKg        Decimal?             @db.Decimal(12, 3)
  // CAMPOS CIEGOS — jamás serializar para rol PRODUCCION
  unidadesEsperadas        Decimal?             @db.Decimal(12, 3)
  desvioPct                Decimal?             @db.Decimal(7, 2)
  alertaDisparada          Boolean              @default(false)

  insumosUsados InsumoUsado[]

  @@map("lotes_produccion")
}

model InsumoUsado {
  id                   Int              @id @default(autoincrement())
  loteDeProduccion     LoteDeProduccion @relation(fields: [loteDeProduccionId], references: [id])
  loteDeProduccionId   Int
  productoInsumo       Producto         @relation(fields: [productoInsumoId], references: [id])
  productoInsumoId     Int
  lineaIngresoOrigen   LineaIngreso     @relation(fields: [lineaIngresoOrigenId], references: [id])
  lineaIngresoOrigenId Int
  cantidadUsada        Decimal          @db.Decimal(12, 3)

  @@map("insumos_usados")
}

// ─────────────────────────────────────────────
// MÓDULO 1 — FLUJO 3: TRANSFERENCIAS
// ─────────────────────────────────────────────

model Transferencia {
  id                 Int                 @id @default(autoincrement())
  sucursalOrigen     Sucursal            @relation("TransferenciaOrigen", fields: [sucursalOrigenId], references: [id])
  sucursalOrigenId   Int
  sucursalDestino    Sucursal            @relation("TransferenciaDestino", fields: [sucursalDestinoId], references: [id])
  sucursalDestinoId  Int
  fechaHoraEnvio     DateTime            @default(now())
  usuarioEmisor      Usuario             @relation("TransferenciaEmisor", fields: [usuarioEmisorId], references: [id])
  usuarioEmisorId    Int
  usuarioReceptor    Usuario?            @relation("TransferenciaReceptor", fields: [usuarioReceptorId], references: [id])
  usuarioReceptorId  Int?
  fechaHoraRecepcion DateTime?
  estado             EstadoTransferencia @default(PENDIENTE_RECEPCION)

  lineas LineaDeTransferencia[]

  @@map("transferencias")
}

model LineaDeTransferencia {
  id               Int           @id @default(autoincrement())
  transferencia    Transferencia @relation(fields: [transferenciaId], references: [id])
  transferenciaId  Int
  producto         Producto      @relation(fields: [productoId], references: [id])
  productoId       Int
  // CAMPO CIEGO para el receptor antes de confirmar
  cantidadEnviada  Decimal       @db.Decimal(12, 3)
  cantidadRecibida Decimal?      @db.Decimal(12, 3)
  diferencia       Decimal?      @db.Decimal(12, 3)

  @@unique([transferenciaId, productoId])
  @@map("lineas_transferencia")
}

// ─────────────────────────────────────────────
// MÓDULO 2 — POS + CAJA Y TURNOS
// ─────────────────────────────────────────────
//
// Convenciones de este módulo (ver CLAUDE.md del módulo 2, sección
// "Correcciones al borrador del cliente" del plan de implementación):
//  - IDs Int autoincrement en todo, como el resto del schema (el borrador
//    original del cliente proponía String/cuid; se descartó por consistencia).
//  - Los combos NO tienen modelo propio: son Producto con tipo=COMBO. Vender
//    un combo usa productoId igual que cualquier producto — no hay comboId
//    en ItemDePedido ni en Atencion.
//  - TipoMovimientoStock y TipoAlerta ya traían los valores que este módulo
//    necesita, reservados desde el Módulo 1 (VENTA, ATENCION, MERMA_QUEMADO,
//    RETORNO_A_PRODUCCION, MARCADO_POLLO, ANULACION_REPOSICION, AJUSTE /
//    DISCREPANCIA_CAJA, BLOQUEO_TURNO, STOCK_MINIMO) — no se tocan esos enums.
//  - Montos de dinero: Decimal(12,2) (igual que Precio.monto). Cantidades/
//    stock: Decimal(12,3) (igual que MovimientoStock.cantidad).

model Turno {
  id              Int         @id @default(autoincrement())
  sucursal        Sucursal    @relation(fields: [sucursalId], references: [id])
  sucursalId      Int
  usuarioCajero   Usuario     @relation(fields: [usuarioCajeroId], references: [id])
  usuarioCajeroId Int
  fechaApertura   DateTime    @default(now())
  fechaCierre     DateTime?
  estado          EstadoTurno @default(ABIERTO)

  arqueos          Arqueo[]
  bloqueo          BloqueoDeTurno?
  pedidos          Pedido[]
  atenciones       Atencion[]
  gastos           GastoDeCaja[]
  retiros          RetiroDeCaja[]
  eventosMarcado   EventoMarcadoPollo[]
  clavesEmergencia ClaveDeEmergencia[]

  @@index([sucursalId, estado])
  @@map("turnos")
}

// Conteo ciego. El "esperado" y la "diferencia" son campos ciegos: jamás se
// serializan para CAJERO/ENCARGADO (mismo patrón que unidadesEsperadas en
// LoteDeProduccion y cantidadEnviada en LineaDeTransferencia).
model Arqueo {
  id            Int             @id @default(autoincrement())
  turno         Turno           @relation(fields: [turnoId], references: [id])
  turnoId       Int
  momento       MomentoArqueo
  tipo          TipoArqueo
  valorContado  Decimal         @db.Decimal(12, 3)
  // CAMPOS CIEGOS — jamás serializar para rol CAJERO/ENCARGADO
  valorEsperado Decimal         @db.Decimal(12, 3)
  diferencia    Decimal         @db.Decimal(12, 3)
  resultado     ResultadoArqueo
  fechaHora     DateTime        @default(now())

  bloqueosDisparados BloqueoDeTurno[]

  // A lo sumo 4 arqueos por turno: apertura/cierre × efectivo/pollos
  @@unique([turnoId, momento, tipo])
  @@map("arqueos")
}

model BloqueoDeTurno {
  id                      Int                @id @default(autoincrement())
  turno                   Turno              @relation(fields: [turnoId], references: [id])
  turnoId                 Int                @unique
  arqueoQueLoDisparo      Arqueo             @relation(fields: [arqueoQueLoDisparoId], references: [id])
  arqueoQueLoDisparoId    Int
  // Cajero que cerró el turno anterior — a quién preguntarle primero
  usuarioCajeroAnterior   Usuario?           @relation("BloqueoCajeroAnterior", fields: [usuarioCajeroAnteriorId], references: [id])
  usuarioCajeroAnteriorId Int?
  estado                  EstadoBloqueo      @default(BLOQUEADO)
  tipoDesbloqueo          TipoDesbloqueo?
  usuarioAutorizante      Usuario?           @relation("BloqueoAutorizante", fields: [usuarioAutorizanteId], references: [id])
  usuarioAutorizanteId    Int?
  fechaDesbloqueo         DateTime?
  claveEmergencia         ClaveDeEmergencia? @relation(fields: [claveEmergenciaId], references: [id])
  claveEmergenciaId       Int?
  createdAt               DateTime           @default(now())

  @@map("bloqueos_turno")
}

// Código de un solo uso para desbloquear una caja sin que el admin esté
// disponible remotamente. Expira a los 10 minutos (validado por servicio).
model ClaveDeEmergencia {
  id            Int       @id @default(autoincrement())
  codigo        String    @unique
  generadaPor   Usuario   @relation(fields: [generadaPorId], references: [id])
  generadaPorId Int
  turno         Turno?    @relation(fields: [turnoId], references: [id])
  turnoId       Int?
  expiraEn      DateTime
  usada         Boolean   @default(false)
  usadaEn       DateTime?
  createdAt     DateTime  @default(now())

  bloqueosDesbloqueados BloqueoDeTurno[]

  @@map("claves_emergencia")
}

model Pedido {
  id              Int          @id @default(autoincrement())
  turno           Turno        @relation(fields: [turnoId], references: [id])
  turnoId         Int
  sucursal        Sucursal     @relation(fields: [sucursalId], references: [id])
  sucursalId      Int
  tipo            TipoPedido
  estado          EstadoPedido @default(EN_PREPARACION)
  usuarioCajero   Usuario      @relation(fields: [usuarioCajeroId], references: [id])
  usuarioCajeroId Int
  // Si viene de un pedido LISTO_NO_RETIRADO reasignado a otro cliente
  pedidoOrigen    Pedido?      @relation("Reasignacion", fields: [pedidoOrigenId], references: [id])
  pedidoOrigenId  Int?
  reasignaciones  Pedido[]     @relation("Reasignacion")

  // Campos previstos para AFIP/ARCA (fuera de alcance, CLAUDE.md módulo 1 §3)
  cuit           String?
  condicionIva   String?
  nroComprobante String?
  // Canal de origen (WhatsApp es futuro lejano — hoy siempre mostrador)
  canalOrigen    String  @default("MOSTRADOR")

  items   ItemDePedido[]
  pagos   Pago[]
  tickets TicketCocina[]

  fechaCreacion DateTime  @default(now())
  fechaCierre   DateTime?

  @@index([sucursalId, estado])
  @@index([turnoId])
  @@map("pedidos")
}

model ItemDePedido {
  id               Int            @id @default(autoincrement())
  pedido           Pedido         @relation(fields: [pedidoId], references: [id])
  pedidoId         Int
  // Cubre productos normales Y combos (Producto.tipo=COMBO) — no hay comboId
  producto         Producto       @relation(fields: [productoId], references: [id])
  productoId       Int
  cantidad         Decimal        @db.Decimal(12, 3)
  // Total CONGELADO de la línea al confirmar — fuente de verdad del cobro.
  // Con la tabla de precio por volumen (Precio.cantidad) el total de N
  // unidades NO es N × unitario (ej: 6 empanadas $8.500 ≠ 6 × $1.600), por
  // eso se congela el total y el unitario queda solo como referencia.
  montoTotal       Decimal        @db.Decimal(12, 2)
  // Referencia informativa: montoTotal / cantidad redondeado a 2 decimales
  precioUnitario   Decimal        @db.Decimal(12, 2)
  aclaraciones     String?
  esVentaCostoCero Boolean        @default(false)
  tipoCostoCero    TipoCostoCero?

  @@map("items_pedido")
}

model Pago {
  id        Int       @id @default(autoincrement())
  pedido    Pedido    @relation(fields: [pedidoId], references: [id])
  pedidoId  Int
  medio     MedioPago
  monto     Decimal   @db.Decimal(12, 2)
  fechaHora DateTime  @default(now())

  @@map("pagos")
}

// Regalías / productos sin cargo. Descuenta stock igual que una venta
// (MovimientoStock tipo ATENCION) pero no genera Pago.
model Atencion {
  id            Int      @id @default(autoincrement())
  turno         Turno    @relation(fields: [turnoId], references: [id])
  turnoId       Int
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id])
  sucursalId    Int
  producto      Producto @relation(fields: [productoId], references: [id])
  productoId    Int
  cantidad      Decimal  @db.Decimal(12, 3)
  motivoCodigo  String
  motivoDetalle String?
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId     Int
  fechaHora     DateTime @default(now())

  @@map("atenciones")
}

model GastoDeCaja {
  id          Int       @id @default(autoincrement())
  turno       Turno     @relation(fields: [turnoId], references: [id])
  turnoId     Int
  monto       Decimal   @db.Decimal(12, 2)
  medio       MedioPago // Solo EFECTIVO o MERCADO_PAGO en la práctica (validado en servicio)
  categoria   String
  descripcion String?
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  usuarioId   Int
  fechaHora   DateTime  @default(now())

  @@map("gastos_caja")
}

model RetiroDeCaja {
  id              Int         @id @default(autoincrement())
  turno           Turno       @relation(fields: [turnoId], references: [id])
  turnoId         Int
  monto           Decimal     @db.Decimal(12, 2)
  medio           MedioPago
  socio           SocioRetiro // Selector cerrado — nunca texto libre
  usuarioCajero   Usuario     @relation(fields: [usuarioCajeroId], references: [id])
  usuarioCajeroId Int
  fechaHora       DateTime    @default(now())

  @@map("retiros_caja")
}

// Registra "se tiraron X pollos a la parrilla": fresco -> marcado. Dentro de
// la misma transacción genera 2 MovimientoStock (tipo MARCADO_POLLO): uno
// negativo sobre "Pollo a la leña (entero)" y uno positivo sobre "Pollo a la
// leña (entero) — MARCADO" (producto nuevo del seed, ver plan del módulo 2).
model EventoMarcadoPollo {
  id         Int      @id @default(autoincrement())
  turno      Turno    @relation(fields: [turnoId], references: [id])
  turnoId    Int
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  sucursalId Int
  cantidad   Decimal  @db.Decimal(12, 3)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId  Int
  fechaHora  DateTime @default(now())

  @@map("eventos_marcado_pollo")
}

// Snapshot de lo enviado a la comandera (mock ahora, ESC/POS real después).
model TicketCocina {
  id             Int        @id @default(autoincrement())
  pedido         Pedido     @relation(fields: [pedidoId], references: [id])
  pedidoId       Int
  tipo           TipoTicket
  contenido      Json
  fechaHora      DateTime   @default(now())
  impreso        Boolean    @default(false)
  errorImpresion String?

  @@map("tickets_cocina")
}

model ConfiguracionStockMinimo {
  id         Int      @id @default(autoincrement())
  producto   Producto @relation(fields: [productoId], references: [id])
  productoId Int
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  sucursalId Int
  minimo     Decimal  @db.Decimal(12, 3)
  activa     Boolean  @default(true)

  @@unique([productoId, sucursalId])
  @@map("configuraciones_stock_minimo")
}
